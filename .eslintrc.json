{
  "env": {
    "commonjs": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": 2022
  },
  "ignorePatterns": [],
  "rules": {
    "no-unused-vars": ["error", { "ignoreRestSiblings": true }],
    "no-extra-boolean-cast": 0,
    "no-case-declarations": 0,
    "no-constant-condition": 0
  }
}